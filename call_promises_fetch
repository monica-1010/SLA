<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Async JS: From Callbacks to Await</title>
    <style>
        body { font-family: sans-serif; padding: 40px; background: #f4f4f9; color: #333; }
        .container { max-width: 500px; margin: auto; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        button { width: 100%; padding: 12px; margin-bottom: 10px; cursor: pointer; border: none; border-radius: 6px; background: #6c5ce7; color: white; font-weight: bold; }
        button:hover { background: #5b4cc4; }
        .status { padding: 10px; background: #eee; border-radius: 4px; font-family: monospace; min-height: 20px; }
    </style>
</head>
<body>

<div class="container">
    <h2>Async Operations Task</h2>
    <p>Click buttons to see different async methods in the console and below:</p>
    
    <button onclick="runCallback()">1. Run Callback</button>
    <button onclick="runPromise()">2. Run Promise</button>
    <button onclick="runFetch()">3. Run Fetch (API)</button>
    <button onclick="runAsyncAwait()">4. Run Async/Await</button>

    <div class="status" id="output">Output will appear here...</div>
</div>

<script>
    const output = document.getElementById('output');

    // --- 1. CALLBACK ---
    // A function passed as an argument to another function.
    function runCallback() {
        output.innerText = "Loading with Callback...";
        setTimeout(() => {
            finishCallback("Data loaded via Callback!);
        }, 1500);
    }

    function finishCallback(message) {
        output.innerText = message;
    }


    // --- 2. PROMISE ---
    // An object representing the eventual completion of an async operation.
    function runPromise() {
        output.innerText = "Loading with Promise...";
        
        const myPromise = new Promise((resolve, reject) => {
            setTimeout(() => {
                resolve("Data loaded via Promise!");
            }, 1500);
        });

        myPromise.then(result => output.innerText = result);
    }


    // --- 3. FETCH ---
    // A built-in way to get data from a URL (returns a Promise).
    function runFetch() {
        output.innerText = "Fetching from API...";
        
        fetch('https://jsonplaceholder.typicode.com/todos/1')
            .then(response => response.json()) // Convert to JSON
            .then(data => {
                output.innerText = `Fetch Success: ${data.title}`;
            })
            .catch(err => output.innerText = "Error fetching data.");
    }


    // --- 4. ASYNC / AWAIT ---
    // Modern syntax that makes async code look "synchronous" and cleaner.
    async function runAsyncAwait() {
        output.innerText = "Loading with Async/Await...";
        
        try {
            // Wait for the fetch to finish before moving to the next line
            const response = await fetch('https://jsonplaceholder.typicode.com/todos/2');
            const data = await response.json();
            
            output.innerText = `Async/Await Success: ${data.title}`;
        } catch (error) {
            output.innerText = "Something went wrong.";
        }
    }
</script>

</body>
</html>
