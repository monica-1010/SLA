<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Practice</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Just for visualization purposes */
        .col, .col-lg-4, .col-6 {
            border: 1px solid #dee2e6;
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>

    <div class="container my-5">
        
        <h1 class="text-center text-primary mb-4">Bootstrap Layout Practice</h1>
        <p class="lead text-center mb-5">A responsive, nested grid example using utility classes.</p>

        <div class="row g-4">
            
            <div class="col-lg-4 col-md-6 col-12 p-3">
                <h3>Column 1</h3>
                <p>This column is responsive. It will stack on small screens and sit side-by-side on large ones.</p>
            </div>

            <div class="col-lg-4 col-md-6 col-12 p-3">
                <h3>Column 2 (Nested)</h3>
                <div class="row bg-white p-2 border">
                    <div class="col-6 text-success fw-bold">Sub-col A</div>
                    <div class="col-6 text-danger fw-bold">Sub-col B</div>
                </div>
            </div>

            <div class="col-lg-4 col-12 p-3">
                <h3 class="text-secondary">Column 3</h3>
                <p class="m-0">Notice the <code>m-0</code> and <code>p-3</code> utilities used here to control the flow.</p>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
