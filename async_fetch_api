<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Async Fetch Task</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; display: flex; justify-content: center; padding: 50px; }
        .user-card { background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 300px; text-align: center; }
        img { border-radius: 50%; width: 100px; border: 3px solid #6c5ce7; }
        .loader { color: #666; font-style: italic; display: none; }
        button { background: #6c5ce7; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; margin-top: 15px; }
        button:hover { background: #5b4cc4; }
    </style>
</head>
<body>

<div class="user-card">
    <div id="loader" class="loader">Fetching user...</div>
    <div id="user-content">
        <img id="user-pic" src="" alt="User Image" style="display:none;">
        <h2 id="user-name">Click to Load</h2>
        <p id="user-email"></p>
    </div>
    <button onclick="fetchRandomUser()">Get New User</button>
</div>

<script>
    // THE ASYNC/AWAIT TASK
    async function fetchRandomUser() {
        const loader = document.getElementById('loader');
        const content = document.getElementById('user-content');
        const nameEl = document.getElementById('user-name');
        const emailEl = document.getElementById('user-email');
        const picEl = document.getElementById('user-pic');

        // 1. Show loader, hide old content
        loader.style.display = "block";
        content.style.opacity = "0.3";

        try {
            // 2. FETCH the data (The 'Await' part)
            const response = await fetch('https://randomuser.me/api/');
            
            // 3. Convert response to JSON (Also needs 'Await')
            const data = await response.json();
            
            // 4. Extract data (Destructuring)
            const user = data.results[0];
            
            // 5. Update UI
            nameEl.innerText = `${user.name.first} ${user.name.last}`;
            emailEl.innerText = user.email;
            picEl.src = user.picture.large;
            picEl.style.display = "inline-block";

        } catch (error) {
            nameEl.innerText = "Error loading user!";
            console.error("Fetch Error:", error);
        } finally {
            // 6. Hide loader
            loader.style.display = "none";
            content.style.opacity = "1";
        }
    }
</script>

</body>
</html>
