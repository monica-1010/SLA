  buttonSecondary: { backgroundColor: '#28a745', color: 'white', border: 'none', padding: '10px', cursor: 'pointer', width: '100%' },
  preview: { marginTop: '15px', padding: '10px', backgroundColor: '#e9ecef', borderRadius: '4px' },
